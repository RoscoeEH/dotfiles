[{
  "layer": "top",
  "position": "top",
  "height": 30,

  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "custom/jellyfin",
    "custom/scratchpad"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "pulseaudio",
    "network#eth",
    "network#wifi",
    "custom/vpn",
    "battery"
  ],

  // Jellyfin
  "custom/jellyfin": {
  "format": "Jellyfin: {}",
  "exec": "bash -c 'systemctl is-active --quiet jellyfin 2>/dev/null && echo Active'",
  "interval": 60,
  "signal": 5
  },


  // Scratchpad
  "custom/scratchpad": {
    "format": " {}",
    "exec": "bash -c 'swaymsg -t get_tree | jq \"[.. | objects | select(.scratchpad_state != null and .scratchpad_state != \\\"none\\\")] | length\"'",
    "interval": 5,
    "signal": 2
  },

  // Mode indicator
  "sway/mode": {
    "format": "MODE: {}"
  },

  // Volume
  "pulseaudio": {
  "format": "{icon} {volume}%",
  "format-muted": " MUTE",
  "format-icons": {
    "headphone": "",
    "headset": "",
    "hands-free": "",
    "default": ["", ""]
  },
  "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  "on-click-right": "pavucontrol"
},

  // Ethernet
  "network#eth": {
    "interface": "eth0",
    "format": " {ipaddr}",
    "format-disconnected": "",
    "interval": 60
  },

  // WiFi
  "network#wifi": {
    "interface": "wlp1s0",
    "format": " {essid}",
    "format-disconnected": "睊 APM",
    "interval": 15,
    "signal": 4
  },

  // VPN
  "custom/vpn": {
  "format": " {}",
  "exec": "bash -c 'status=$(nordvpn status 2>/dev/null); if echo \"$status\" | grep -q Connected; then echo \"$status\" | grep \"City:\" | cut -d: -f2- | xargs; else echo Disconnected; fi'",
  "interval": 5,
  "signal": 3
  },

  // Battery
  "battery": {
    "bat": "BAT1",
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 10
    },
    "events": {
        "on-discharging-warning": "notify-send -u normal 'Low Battery'",
        "on-discharging-critical": "notify-send -u critical 'Battery Critical'"
    },
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-discharging": "{capacity}% {icon}",
    "format-icons": ["", "", "", "", ""],
    "max-length": 25
  },

  // Clock
  "clock": {
    "format": "{:%A %m-%d-%Y %H:%M %Z}",
    "interval": 10
  }
}]
[{
  "layer": "top",
  "position": "top",
  "height": 1,

  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "custom/scratchpad",
    "custom/notifications",
    "custom/idle"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "pulseaudio",
    "network#eth",
    "network#wifi",
    "custom/vpn",
    "battery"
  ],

  // Jellyfin
  "custom/jellyfin": {
  "format": "Jellyfin: {}",
  "exec": "bash -c 'systemctl is-active --quiet jellyfin 2>/dev/null && echo Active'",
  "interval": 60,
  "signal": 5
  },


  // Scratchpad
  "custom/scratchpad": {
    "format": " {}",
    "exec": "bash -c 'swaymsg -t get_tree | jq \"[.. | objects | select(.scratchpad_state != null and .scratchpad_state != \\\"none\\\")] | length\"'",
    "interval": 5,
    "signal": 2
  },

  // Notfications
  "custom/notifications": {
    "format": " {}",
    "exec": "~/.config/waybar/customs/notification-status.sh",
    "return-type": "json",
    "interval": 30,
  },

  // Mode indicator
  "sway/mode": {
    "format": "MODE: {}"
  },

  // Idle
  "custom/idle": {
      "exec": "test -f /tmp/idle-inhibit.lock && echo '󰒳 ON' || echo '󰒲 OFF'",
      "interval": 1,
      "on-click": "~/Tools/idle-toggle.sh",
      "signal": 6
  },

  // Volume
  "pulseaudio": {
  "format": "{icon} {volume}%",
  "format-muted": " MUTE",
  "format-icons": {
    "headphone": "",
    "headset": "",
    "hands-free": "",
    "default": ["", ""]
  },
  "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  "on-click-right": "pavucontrol"
},

  // Ethernet
  "network#eth": {
    "interface": "eth0",
    "format": " {ipaddr}",
    "format-disconnected": "",
    "interval": 60
  },

  // WiFi
  "network#wifi": {
    "interface": "wlp192s0",
    "format": "{ifname}",
    "format-wifi": " {essid} ({signalStrength}%)",
    "format-disconnected": "",
    "interval": 15,
    "signal": 4
  },

  // VPN
  "custom/vpn": {
  "format": " {}",
  "exec": "bash -c '~/.config/waybar/customs/vpn-status.sh'",
  "interval": 5,
  "signal": 3
  },


  // Clock
  "clock": {
    "format": "{:%A %m-%d-%Y %H:%M %Z}",
    "interval": 10
  }
}]
[notifications]
label=Notifs:
command=~/.config/i3blocks/notification-status.sh
interval=1

[hidden]
label=Min:
command=/bin/bash -c 'i3-msg -t get_tree | jq "[.. | objects | select(.scratchpad_state != null and .scratchpad_state != \"none\")] | length"'
interval=30
signal=2

[volume]
label=Vol:
command=~/.config/i3blocks/volume-status.sh
interval=5
signal=1

[network]
command=~/.config/i3blocks/network-status.sh
interval=5
signal=4

[tailscale]
label=TS:
command=~/.config/i3blocks/tailscale-status.sh
interval=15
signal=3

[battery]
command=~/.config/i3blocks/battery-status.sh
interval=60

[time]
command=date '+%a %m-%d-%y %H:%M %Z'
interval=30
color=#1ce81c
